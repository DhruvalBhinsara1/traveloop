generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                 @id @default(autoincrement())
  name                    String
  username                String              @unique
  email                   String              @unique
  password                String
  avatarUrl               String?
  createdAt               DateTime            @default(now())
  trips                   Trip[]
  sentFriendRequests      FriendRequest[]     @relation("SentFriendRequests")
  receivedFriendRequests  FriendRequest[]     @relation("ReceivedFriendRequests")
  friendshipsAsUserA      Friendship[]        @relation("FriendshipUserA")
  friendshipsAsUserB      Friendship[]        @relation("FriendshipUserB")
  ownedGroups             FriendGroup[]
  groupMemberships        FriendGroupMember[]
  tripMemberships         TripMember[]
  billParticipants        BillParticipant[]
  createdBillExpenses     BillExpense[]       @relation("BillExpenseCreatedBy")
  updatedBillExpenses     BillExpense[]       @relation("BillExpenseUpdatedBy")
  deletedBillExpenses     BillExpense[]       @relation("BillExpenseDeletedBy")
  recordedBillSettlements BillSettlement[]    @relation("BillSettlementRecordedBy")
}

model Trip {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  coverImage  String?
  budget      Float?
  currency    String    @default("USD")
  startDate   DateTime
  endDate     DateTime
  isPublic    Boolean   @default(false)
  shareToken  String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  groupId     Int?
  group       FriendGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  members     TripMember[]
  stops       Stop[]
  checklist   ChecklistItem[]
  notes       Note[]
  billParticipants BillParticipant[]
  billExpenses     BillExpense[]
  billSettlements  BillSettlement[]

  @@index([userId])
  @@index([groupId])
}

model FriendRequest {
  id          Int       @id @default(autoincrement())
  requesterId Int
  recipientId Int
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  respondedAt DateTime?
  requester   User      @relation("SentFriendRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient   User      @relation("ReceivedFriendRequests", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([recipientId, status])
  @@index([requesterId, status])
}

model Friendship {
  id        Int      @id @default(autoincrement())
  userAId   Int
  userBId   Int
  createdAt DateTime @default(now())
  userA     User     @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userBId])
}

model FriendGroup {
  id        Int                 @id @default(autoincrement())
  name      String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  ownerId   Int
  owner     User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members   FriendGroupMember[]
  trips     Trip[]

  @@index([ownerId])
}

model FriendGroupMember {
  id        Int         @id @default(autoincrement())
  createdAt DateTime    @default(now())
  groupId   Int
  userId    Int
  group     FriendGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

model TripMember {
  id        Int      @id @default(autoincrement())
  role      String   @default("editor")
  createdAt DateTime @default(now())
  tripId    Int
  userId    Int
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([userId])
}

model Stop {
  id          Int        @id @default(autoincrement())
  cityName    String
  country     String
  arrivalDate DateTime
  departDate  DateTime
  order       Int
  tripId      Int
  trip        Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities  Activity[]

  @@index([tripId])
}

model Activity {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  category    String
  cost        Float     @default(0)
  duration    Int?
  date        DateTime?
  stopId      Int
  stop        Stop      @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@index([stopId])
}

model ChecklistItem {
  id       Int     @id @default(autoincrement())
  label    String
  isPacked Boolean @default(false)
  category String
  tripId   Int
  trip     Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model Note {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tripId    Int
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model BillParticipant {
  id                  Int                  @id @default(autoincrement())
  name                String
  status              String               @default("active")
  archivedAt          DateTime?
  createdAt           DateTime             @default(now())
  tripId              Int
  userId              Int?
  trip                Trip                 @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  paidExpenses        BillExpense[]        @relation("LegacyPaidExpenses")
  expensePayments     BillExpensePayment[]
  expenseShares       BillExpenseShare[]
  settlementsSent     BillSettlement[]     @relation("SettlementFromParticipant")
  settlementsReceived BillSettlement[]     @relation("SettlementToParticipant")

  @@index([tripId])
  @@index([tripId, archivedAt])
  @@index([userId])
  @@unique([tripId, userId])
}

model BillExpense {
  id              Int                  @id @default(autoincrement())
  title           String
  amount          Float
  amountCents     Int                  @default(0)
  currency        String               @default("USD")
  splitMode       String               @default("equal")
  category        String?
  note            String?
  paidAt          DateTime             @default(now())
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @default(now()) @updatedAt
  deletedAt       DateTime?
  tripId          Int
  paidById        Int
  createdByUserId Int?
  updatedByUserId Int?
  deletedByUserId Int?
  trip            Trip                 @relation(fields: [tripId], references: [id], onDelete: Cascade)
  paidBy          BillParticipant      @relation("LegacyPaidExpenses", fields: [paidById], references: [id], onDelete: Restrict)
  createdBy       User?                @relation("BillExpenseCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy       User?                @relation("BillExpenseUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedBy       User?                @relation("BillExpenseDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  payments        BillExpensePayment[]
  shares          BillExpenseShare[]

  @@index([tripId])
  @@index([tripId, createdAt])
  @@index([tripId, deletedAt])
  @@index([tripId, currency])
  @@index([paidById])
  @@index([createdByUserId])
}

model BillExpensePayment {
  id            Int             @id @default(autoincrement())
  amountCents   Int
  createdAt     DateTime        @default(now())
  expenseId     Int
  participantId Int
  expense       BillExpense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  participant   BillParticipant @relation(fields: [participantId], references: [id], onDelete: Restrict)

  @@unique([expenseId, participantId])
  @@index([participantId])
}

model BillExpenseShare {
  id            Int             @id @default(autoincrement())
  amountCents   Int
  percentBps    Int?
  shares        Int?
  createdAt     DateTime        @default(now())
  expenseId     Int
  participantId Int
  expense       BillExpense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  participant   BillParticipant @relation(fields: [participantId], references: [id], onDelete: Restrict)

  @@unique([expenseId, participantId])
  @@index([participantId])
}

model BillSettlement {
  id                  Int             @id @default(autoincrement())
  amountCents         Int
  currency            String          @default("USD")
  note                String?
  settledAt           DateTime        @default(now())
  createdAt           DateTime        @default(now())
  deletedAt           DateTime?
  tripId              Int
  fromParticipantId   Int
  toParticipantId     Int
  recordedByUserId    Int?
  trip                Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fromParticipant     BillParticipant @relation("SettlementFromParticipant", fields: [fromParticipantId], references: [id], onDelete: Restrict)
  toParticipant       BillParticipant @relation("SettlementToParticipant", fields: [toParticipantId], references: [id], onDelete: Restrict)
  recordedBy          User?           @relation("BillSettlementRecordedBy", fields: [recordedByUserId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([tripId, deletedAt])
  @@index([fromParticipantId])
  @@index([toParticipantId])
  @@index([recordedByUserId])
}
